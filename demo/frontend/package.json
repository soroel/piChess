{
  "name": "app-platform-demo-frontend",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://soroel.github.io/piChess",
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/chess.js": "^0.13.3",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.37",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "axios": "^1.3.4",
    "chess.js": "^1.0.0-beta.4",
    "normalize.css": "^8.0.1",
    "react": "^18.2.0",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "cross-env PORT=3314 react-scripts start",
    "startNode17": "cross-env PORT=3314 HOST=127.0.0.1 BROWSER=none react-scripts --openssl-legacy-provider start",
    "build": "set PUBLIC_URL=. && set GENERATE_SOURCEMAP=false && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie > 0",
      "not ie_mob > 0"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
